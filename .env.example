# WhatsApp CV Analyzer - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="WhatsApp CV Analyzer"
DEBUG=true
ENVIRONMENT=development

# WhatsApp Cloud API (get from Meta Developer Portal)
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=cv_analyzer_verify_token

# Supabase (get from Supabase Dashboard)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_BUCKET=resumes

# AI Provider: "rule_based", "ollama", or "openai"
AI_PROVIDER=rule_based

# Ollama (if using local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (if using OpenAI API)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Email (optional - for sending reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@cvanalyzer.ai